08B2:  BSF    0A.3
08B3:  MOVF   78,W
08B4:  ANDLW  3F
08B5:  BSF    03.6
08B6:  MOVWF  29
08B7:  MOVWF  32
08B8:  BCF    0A.3
08B9:  BCF    03.6
08BA:  CALL   6C7
08BB:  BSF    0A.3
08BC:  MOVF   78,W
08BD:  MOVWF  27
....................   i2c_stop();
08BE:  BSF    03.5
08BF:  BSF    11.2
08C0:  BTFSC  11.2
08C1:  GOTO   0C0
.................... 
.................... }
.................... 
.................... BYTE bin2bcd(BYTE binary_value)
.................... {
....................   BYTE temp;
....................   BYTE retval;
.................... 
....................   temp = binary_value;
....................   retval = 0;
.................... 
....................   while(1)
....................   {
....................     // Get the tens digit by doing multiple subtraction
....................     // of 10 from the binary value.
....................     if(temp >= 10)
....................     {
....................       temp -= 10;
....................       retval += 0x10;
....................     }
....................     else // Get the ones digit by adding the remainder.
....................     {
....................       retval += temp;
....................       break;
....................     }
....................   }
.................... 
....................   return(retval);
.................... }
.................... 
.................... 
.................... // Input range - 00 to 99.
.................... BYTE bcd2bin(BYTE bcd_value)
.................... {
....................   BYTE temp;
.................... 
....................   temp = bcd_value;
*
06C7:  BSF    03.6
06C8:  MOVF   32,W
06C9:  MOVWF  33
....................   // Shifting upper digit right by 1 is same as multiplying by 8.
....................   temp >>= 1;
06CA:  BCF    03.0
06CB:  RRF    33,F
....................   // Isolate the bits for the upper digit.
....................   temp &= 0x78;
06CC:  MOVLW  78
06CD:  ANDWF  33,F
.................... 
....................   // Now return: (Tens * 8) + (Tens * 2) + Ones
.................... 
....................   return(temp + (temp >> 2) + (bcd_value & 0x0f));
06CE:  RRF    33,W
06CF:  MOVWF  77
06D0:  RRF    77,F
06D1:  MOVLW  3F
06D2:  ANDWF  77,F
06D3:  MOVF   77,W
06D4:  ADDWF  33,W
06D5:  MOVWF  34
06D6:  MOVF   32,W
06D7:  ANDLW  0F
06D8:  ADDWF  34,W
06D9:  MOVWF  78
06DA:  BCF    03.6
06DB:  RETURN
.................... }
.................... int8 leer_temp_DS3232()
.................... {
....................     BYTE msb, lsb;
....................     i2c_start();
....................     i2c_write(0xD0);
....................     i2c_write(0x11); // REG TEMP MSB
....................     i2c_start();
....................     i2c_write(0xD1);
....................     msb = i2c_read(1);
....................     lsb = i2c_read(0);
....................     i2c_stop();
....................     return msb; // solo grados enteros
.................... }
