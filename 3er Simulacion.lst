03A2:  MOVF   44,W
03A3:  MOVWF  78
03A4:  BTFSC  03.2
03A5:  GOTO   3AA
03A6:  BCF    03.0
03A7:  RLF    77,F
03A8:  DECFSZ 78,F
03A9:  GOTO   3A6
03AA:  MOVF   77,W
03AB:  XORLW  FF
03AC:  ANDWF  42,F
.................... 
....................    output_low(GLCD_DI);          // Set for instruction
03AD:  BSF    03.5
03AE:  BCF    03.6
03AF:  BCF    06.2
03B0:  BCF    03.5
03B1:  BCF    06.2
....................    glcd_writeByte(side, x);      // Set the horizontal address
03B2:  MOVLW  00
03B3:  BSF    03.6
03B4:  BTFSC  43.0
03B5:  MOVLW  01
03B6:  MOVWF  44
03B7:  MOVWF  46
03B8:  MOVF   3F,W
03B9:  MOVWF  47
03BA:  BCF    03.6
03BB:  CALL   1F1
....................    output_high(GLCD_DI);         // Set for data
03BC:  BSF    03.5
03BD:  BCF    06.2
03BE:  BCF    03.5
03BF:  BSF    06.2
....................    glcd_writeByte(side, data);   // Write the pixel data
03C0:  MOVLW  00
03C1:  BSF    03.6
03C2:  BTFSC  43.0
03C3:  MOVLW  01
03C4:  MOVWF  44
03C5:  MOVWF  46
03C6:  MOVF   42,W
03C7:  MOVWF  47
03C8:  BCF    03.6
03C9:  CALL   1F1
03CA:  RETURN
.................... }
.................... #endif
.................... 
.................... 
.................... // Purpose:    Fill the LCD screen with the passed in color
.................... // Inputs:     ON  - turn all the pixels on
.................... //             OFF - turn all the pixels off
.................... void glcd_fillScreen(int1 color)
.................... #ifdef FAST_GLCD
.................... {
....................    unsigned int8  data;
....................    unsigned int8  *p1, *p2;
....................    unsigned int16 i;
.................... 
....................    p1 = displayData.left;
....................    p2 = displayData.right;
....................    data = 0xFF * color;
.................... 
....................    for(i=0; i<512; ++i)
....................    {
....................       *p1++ = data;
....................       *p2++ = data;
....................    }
.................... }
.................... #else
.................... {
....................    unsigned int8 i, j;
.................... 
....................    // Loop through the vertical pages
....................    for(i = 0; i < 8; ++i)
*
024F:  BSF    03.6
0250:  CLRF   2F
0251:  MOVF   2F,W
0252:  SUBLW  07
0253:  BTFSS  03.0
0254:  GOTO   2A7
....................    {
....................       output_low(GLCD_DI);                      // Set for instruction
0255:  BSF    03.5
0256:  BCF    03.6
0257:  BCF    06.2
0258:  BCF    03.5
0259:  BCF    06.2
....................       glcd_writeByte(GLCD_LEFT, 0b01000000);    // Set horizontal address to 0
025A:  BSF    03.6
025B:  CLRF   46
025C:  MOVLW  40
025D:  MOVWF  47
025E:  BCF    03.6
025F:  CALL   1F1
....................       glcd_writeByte(GLCD_RIGHT, 0b01000000);
0260:  MOVLW  01
0261:  BSF    03.6
0262:  MOVWF  46
0263:  MOVLW  40
0264:  MOVWF  47
0265:  BCF    03.6
0266:  CALL   1F1
....................       glcd_writeByte(GLCD_LEFT, i | 0b10111000);// Set page address
0267:  BSF    03.6
0268:  MOVF   2F,W
0269:  IORLW  B8
026A:  MOVWF  31
026B:  CLRF   46
026C:  MOVF   31,W
026D:  MOVWF  47
026E:  BCF    03.6
026F:  CALL   1F1
....................       glcd_writeByte(GLCD_RIGHT, i | 0b10111000);
0270:  BSF    03.6
0271:  MOVF   2F,W
0272:  IORLW  B8
0273:  MOVWF  31
0274:  MOVLW  01
0275:  MOVWF  46
0276:  MOVF   31,W
0277:  MOVWF  47
0278:  BCF    03.6
0279:  CALL   1F1
....................       output_high(GLCD_DI);                     // Set for data
027A:  BSF    03.5
027B:  BCF    06.2
027C:  BCF    03.5
027D:  BSF    06.2
.................... 
....................       // Loop through the horizontal sections
....................       for(j = 0; j < 64; ++j)
027E:  BSF    03.6
027F:  CLRF   30
0280:  MOVF   30,W
0281:  SUBLW  3F
0282:  BTFSS  03.0
0283:  GOTO   2A5
....................       {
....................          glcd_writeByte(GLCD_LEFT, 0xFF*color);  // Turn pixels on or off
0284:  MOVLW  FF
0285:  MOVWF  3F
0286:  MOVF   2E,W
0287:  MOVWF  40
0288:  BCF    03.6
0289:  CALL   228
028A:  MOVF   78,W
028B:  BSF    03.6
028C:  MOVWF  31
028D:  CLRF   46
028E:  MOVF   31,W
028F:  MOVWF  47
0290:  BCF    03.6
0291:  CALL   1F1
....................          glcd_writeByte(GLCD_RIGHT, 0xFF*color); // Turn pixels on or off
0292:  MOVLW  FF
0293:  BSF    03.6
0294:  MOVWF  3F
0295:  MOVF   2E,W
0296:  MOVWF  40
0297:  BCF    03.6
0298:  CALL   228
0299:  MOVF   78,W
029A:  BSF    03.6
029B:  MOVWF  31
029C:  MOVLW  01
029D:  MOVWF  46
029E:  MOVF   31,W
029F:  MOVWF  47
02A0:  BCF    03.6
02A1:  CALL   1F1
02A2:  BSF    03.6
02A3:  INCF   30,F
02A4:  GOTO   280
....................       }
02A5:  INCF   2F,F
02A6:  GOTO   251
....................    }
02A7:  BCF    03.6
02A8:  RETURN
.................... }
.................... #endif
.................... 
.................... 
.................... // Purpose:    Write a byte of data to the specified chip
.................... // Inputs:     1) chipSelect - which chip to write the data to
.................... //             2) data - the byte of data to write
.................... void glcd_writeByte(int1 side, BYTE data)
.................... {
....................    TrisPort(0x00);
*
01F1:  MOVLW  00
01F2:  BSF    03.5
01F3:  MOVWF  08
....................    
....................    output_low(GLCD_RW);       // Set for writing
01F4:  BCF    06.3
01F5:  BCF    03.5
01F6:  BCF    06.3
.................... 
....................     if(side)                   // Choose which side to write to
01F7:  BSF    03.6
01F8:  MOVF   46,F
01F9:  BTFSC  03.2
01FA:  GOTO   202
....................       output_high(GLCD_CS2);
01FB:  BSF    03.5
01FC:  BCF    03.6
01FD:  BCF    06.1
01FE:  BCF    03.5
01FF:  BSF    06.1
0200:  GOTO   207
0201:  BSF    03.6
....................    else
....................       output_high(GLCD_CS1);
0202:  BSF    03.5
0203:  BCF    03.6
0204:  BCF    06.0
0205:  BCF    03.5
0206:  BSF    06.0
.................... 
....................     delay_us(1);
0207:  GOTO   208
0208:  GOTO   209
0209:  NOP
.................... 
....................    WritePort(data);           // Put the data on the port
020A:  BSF    03.5
020B:  CLRF   08
020C:  BCF    03.5
020D:  BSF    03.6
020E:  MOVF   47,W
020F:  BCF    03.6
0210:  MOVWF  08
....................    delay_us(1);
0211:  GOTO   212
0212:  GOTO   213
0213:  NOP
....................    output_high(GLCD_E);       // Pulse the enable pin
0214:  BSF    03.5
0215:  BCF    06.4
0216:  BCF    03.5
0217:  BSF    06.4
....................    delay_us(1);
0218:  GOTO   219
0219:  GOTO   21A
021A:  NOP
....................    output_low(GLCD_E);
021B:  BSF    03.5
021C:  BCF    06.4
021D:  BCF    03.5
021E:  BCF    06.4
.................... 
....................    output_low(GLCD_CS1);      // Reset the chip select lines
021F:  BSF    03.5
0220:  BCF    06.0
0221:  BCF    03.5
0222:  BCF    06.0
....................    output_low(GLCD_CS2);
0223:  BSF    03.5
0224:  BCF    06.1
0225:  BCF    03.5
0226:  BCF    06.1
0227:  RETURN
.................... }
.................... 
.................... 
.................... // Purpose:    Reads a byte of data from the specified chip
.................... // Outputs:     A byte of data read from the chip
.................... BYTE glcd_readByte(int1 side)
.................... {
....................    BYTE data;                 // Stores the data read from the LCD
.................... 
....................    TrisPort(0xFF);            // Set port to input
*
030C:  MOVLW  FF
030D:  BSF    03.5
030E:  MOVWF  08
....................    output_high(GLCD_RW);      // Set for reading
030F:  BCF    06.3
0310:  BCF    03.5
0311:  BSF    06.3
.................... 
....................    if(side)                   // Choose which side to write to
0312:  BSF    03.6
0313:  MOVF   45,F
0314:  BTFSC  03.2
0315:  GOTO   31D
....................       output_high(GLCD_CS2);
0316:  BSF    03.5
0317:  BCF    03.6
0318:  BCF    06.1
0319:  BCF    03.5
031A:  BSF    06.1
031B:  GOTO   322
031C:  BSF    03.6
....................    else
....................       output_high(GLCD_CS1);
031D:  BSF    03.5
031E:  BCF    03.6
031F:  BCF    06.0
0320:  BCF    03.5
0321:  BSF    06.0
.................... 
....................    delay_us(1);
0322:  GOTO   323
0323:  GOTO   324
0324:  NOP
....................    output_high(GLCD_E);       // Pulse the enable pin
0325:  BSF    03.5
0326:  BCF    06.4
0327:  BCF    03.5
0328:  BSF    06.4
....................    delay_us(1);
0329:  GOTO   32A
032A:  GOTO   32B
032B:  NOP
....................    data = ReadPort();        // Get the data from the display's output register
032C:  MOVLW  FF
032D:  BSF    03.5
032E:  MOVWF  08
032F:  BCF    03.5
0330:  MOVF   08,W
0331:  BSF    03.6
0332:  MOVWF  46
....................    output_low(GLCD_E);
0333:  BSF    03.5
0334:  BCF    03.6
0335:  BCF    06.4
0336:  BCF    03.5
0337:  BCF    06.4
.................... 
....................    output_low(GLCD_CS1);      // Reset the chip select lines
0338:  BSF    03.5
0339:  BCF    06.0
033A:  BCF    03.5
033B:  BCF    06.0
....................    output_low(GLCD_CS2);
033C:  BSF    03.5
033D:  BCF    06.1
033E:  BCF    03.5
033F:  BCF    06.1
....................    return data;               // Return the read data
0340:  BSF    03.6
0341:  MOVF   46,W
0342:  MOVWF  78
0343:  BCF    03.6
0344:  RETURN
.................... }
.................... 
.................... #endif
