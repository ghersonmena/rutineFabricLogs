// ================= DS1307 DRIVER =================
#use i2c(MASTER, SDA=PIN_C4, SCL=PIN_C3, FAST)

#define DS1307_ADDR 0xD0

int8 ds1307_seconds;
int8 ds1307_minutes;
int8 ds1307_hours;
int8 ds1307_day;
int8 ds1307_month;
int8 ds1307_year;

int8 bcd_to_dec(int8 val) {
   return (val >> 4) * 10 + (val & 0x0F);
}

void ds1307_init(void) {
   i2c_start();
   i2c_write(DS1307_ADDR);
   i2c_write(0x00);
   i2c_write(0x00); // CH = 0
   i2c_stop();
}

void ds1307_get_date_time(void) {
   i2c_start();
   i2c_write(DS1307_ADDR);
   i2c_write(0x00);
   i2c_start();
   i2c_write(DS1307_ADDR | 1);

   ds1307_seconds = bcd_to_dec(i2c_read());
   ds1307_minutes = bcd_to_dec(i2c_read());
   ds1307_hours   = bcd_to_dec(i2c_read());
   i2c_read(); // day of week (no usado)
   ds1307_day     = bcd_to_dec(i2c_read());
   ds1307_month   = bcd_to_dec(i2c_read());
   ds1307_year    = bcd_to_dec(i2c_read(0));

   i2c_stop();
}
int8 dec_to_bcd(int8 val) {
   return ((val / 10) << 4) | (val % 10);
}

void ds1307_set_date_time(
   int8 day,
   int8 month,
   int8 year,
   int8 hour,
   int8 minute,
   int8 second
){
   i2c_start();
   i2c_write(DS1307_ADDR);
   i2c_write(0x00); // empezar en registro 0

   i2c_write(dec_to_bcd(second));
   i2c_write(dec_to_bcd(minute));
   i2c_write(dec_to_bcd(hour));
   i2c_write(0x01); // day of week (no usado)
   i2c_write(dec_to_bcd(day));
   i2c_write(dec_to_bcd(month));
   i2c_write(dec_to_bcd(year));

   i2c_stop();
}

