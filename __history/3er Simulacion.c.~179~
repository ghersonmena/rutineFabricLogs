// ================= EEPROM =================
void guardar_evento(int tipo){
   int addr;
   char txt[25];
   if(event_count >= 40) return;
   addr = 1 + (event_count * 5);
   ds3232_get_date(dia, mes, an, dow);                         // Obtiene le fecha
   ds3232_get_time(hora, min, seg); 
   write_eeprom(addr,   dia);
   write_eeprom(addr+1, mes);
   write_eeprom(addr+2, hora);
   write_eeprom(addr+3, min);
   write_eeprom(addr+4, tipo);
   event_count++;
   write_eeprom(0, event_count);
   glcd_fillScreen(OFF);
   glcd_text57(10,0,txt_registro,1,ON);
   sprintf(txt,"%02u/%02u  %02u:%02u",dia,mes,hora,min);
   glcd_text57(20,25,txt,1,ON);
}

// ================= PANTALLAS =================
void pantalla_carga(){
   glcd_fillScreen(OFF);
   glcd_text57(15,20,txt_boot,1,ON);
   for(int i=0;i<=100;i+=20){
      glcd_rect(10,45,10+i,50,1,1);
      delay_ms(20);
   }
   glcd_fillScreen(OFF);
}
void menu_principal(){
   glcd_fillScreen(OFF);
   glcd_text57(30,10,txt_menu,1,ON);
   glcd_text57(20,30,txt_start,1,ON);
   glcd_text57(20,45,txt_logs,1,ON);
}
// ================= RUN =================
void ejecutar_eventos(){
   if(BTN4){
      output_high(ACT1);
      output_high(ACT2);
      evento_pendiente = 4;
      flag_guardar = 1;
      while(BTN4);
   }
   if(BTN5){
      output_high(ACT3);
      output_high(ACT4);
      evento_pendiente = 5;
      flag_guardar = 1;
      while(BTN5);
   }
   if(BTN6){
      output_high(ACT5);
      output_high(ACT6);
      evento_pendiente = 6;
      flag_guardar = 1;
      while(BTN6);
   }
      
}

// ================= VISOR =================
void mostrar_evento(int index){
   int addr;
   char txt[25];
   if(event_count == 0){
      glcd_fillScreen(OFF);
      glcd_text57(30,30,txt_no_logs,1,ON);
      return;
   }
   addr = 1 + (index * 5);
   int d   = read_eeprom(addr);
   int m   = read_eeprom(addr+1);
   int h   = read_eeprom(addr+2);
   int min = read_eeprom(addr+3);
   int ev  = read_eeprom(addr+4);
   glcd_fillScreen(OFF);
   glcd_text57(10,0,txt_registro,1,ON);
   sprintf(txt,"%02u/%02u  %02u:%02u",d,m,h,min);
   glcd_text57(20,25,txt,1,ON);
   sprintf(txt,"EVENTO BTN %u",ev);
   glcd_text57(20,45,txt,1,ON);
}
void apagar_actuadores(){
   output_low(ACT1);
   output_low(ACT2);
   output_low(ACT3);
   output_low(ACT4);
   output_low(ACT5);
   output_low(ACT6);
}
