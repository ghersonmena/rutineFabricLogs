//!      glcd_text57(10,0,txt_registro,1,ON);
//!      sprintf(txt,"%02u/%02u  %02u:%02u",dia,mes,hora,min);
//!      glcd_text57(20,25,txt,1,ON);
//!      delay_ms(2000);
      // ======= GUARDADO DIFERIDO =======
      if(flag_guardar)
      {
         guardar_evento(evento_pendiente);
         flag_guardar = 0;
      }

      switch(estado)
      {
         case MENU:
            if(!menu_drawn)
            {
               menu_principal();
               menu_drawn = 1;
            }

            if(BTN1)
            {
               glcd_fillScreen(OFF);
               glcd_text57(20,25,txt_run,1,ON);
               estado = RUN;
               menu_drawn = 0;
               while(BTN1);
            }

            if(BTN2)
            {
               view_index = event_count - 1;
               if(view_index < 0) view_index = 0;
               mostrar_evento(view_index);
               estado = VIEW_LOG;
               menu_drawn = 0;
               while(BTN2);
            }
         break;

         case RUN:
            ejecutar_eventos();
            if(BTN3)
            {
               estado = MENU;
               apagar_actuadores();
               while(BTN3);
            }
         break;

         case VIEW_LOG:
            if(BTN1 && view_index < event_count-1)
            {
               view_index++;
               mostrar_evento(view_index);
               while(BTN1);
            }

            if(BTN2 && view_index > 0)
            {
               view_index--;
               mostrar_evento(view_index);
               while(BTN2);
            }

            if(BTN3)
            {
               estado = MENU;
               while(BTN3);
            }
         break;
      }
   }
}

