   event_count = read_eeprom(0);
   if(event_count == 255){
      event_count = 0;
      write_eeprom(0,0);
   }
   pantalla_carga();
   estado = MENU;
   while(TRUE){
      int8 s;
      delay_ms(50);
      ds3232_get_time(hora, min, s);
      glcd_fillScreen(OFF);
//!      sprintf(txt, "MIN=%02u SEC=%02u",min, s);
      glcd_text57(10,30,txt,1,ON);

//!glcd_fillScreen(OFF);
